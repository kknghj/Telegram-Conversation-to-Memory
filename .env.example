# =============================================================================
# Render Background Worker (운영 환경)
# =============================================================================
# Render Dashboard > Environment 에서 아래 값을 설정합니다.
# 실제 비밀 값은 GitHub에 커밋하지 마세요.

# 필수
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# 운영 권장 (Render render.yaml 기본값과 동일)
STORAGE_BACKEND=supabase
OPENAI_MODEL=gpt-5.6-luna
TELEGRAM_OFFLINE_MODE=false

# 회고형 질문 에이전트 — false면 레거시 경로(요약 LLM의 needs_followup)만 사용되어
# question.py의 질문 생성/복구 로직이 아예 실행되지 않는다. 운영에서도 true로 설정한다.
REFLECTION_AGENT_ENABLED=true
REFLECTION_MAX_QUESTIONS=2

# STORAGE_BACKEND=supabase 일 때 필수
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_MEMORIES_TABLE=memories

# Decision Trace (후속 질문·프로젝트 태그 판단 추적)
# DECISION_TRACE_STORE 허용값: file | supabase | noop
DECISION_TRACE_ENABLED=true
DECISION_TRACE_STORE=supabase
DECISION_TRACE_ENVIRONMENT=production

# =============================================================================
# 로컬 개발 전용 (Render에서는 설정하지 않음)
# =============================================================================

# TELEGRAM_OFFLINE_MODE=true
# DEV_CHAT_USER_ID=dev-user
# STORAGE_BACKEND=local_json
# DECISION_TRACE_STORE=file        # 로컬은 data/debug/decision_traces.jsonl에 기록
# DECISION_TRACE_ENVIRONMENT=local
