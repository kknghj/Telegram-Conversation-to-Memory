# Telegram Bot (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# 선택: 모델 (기본 gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# 회고형 대화 에이전트 (기본 false — 기존 요약+질문 1회 동작)
REFLECTION_AGENT_ENABLED=false

# REFLECTION_AGENT_ENABLED=true일 때 세션당 후속 질문 상한 (기본 2)
REFLECTION_MAX_QUESTIONS=2

# 개발 모드: Telegram API 없이 터미널에서 대화 테스트
# TELEGRAM_OFFLINE_MODE=true 로 설정하면 main.py가 dev_chat 모드로 실행됩니다.
# 또는 python dev_chat.py 로 직접 실행할 수 있습니다.
TELEGRAM_OFFLINE_MODE=false
DEV_CHAT_USER_ID=dev-user

# Storage backend: local_json or supabase
STORAGE_BACKEND=local_json

# Supabase (evaluation log remote mirror — server-side only)
# SUPABASE_SECRET_KEY는 GitHub에 커밋하지 않고, 브라우저/프론트엔드에서 사용하지 않는다.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Required only when STORAGE_BACKEND=supabase
SUPABASE_MEMORIES_TABLE=memories
