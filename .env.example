# Telegram Bot (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# 선택: 모델 (기본 gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# 회고형 대화 에이전트 (기본 false — 기존 요약+질문 1회 동작)
REFLECTION_AGENT_ENABLED=false

# REFLECTION_AGENT_ENABLED=true일 때 세션당 후속 질문 상한 (기본 2)
REFLECTION_MAX_QUESTIONS=2
